{
	"exclude": ["node_modules", "src/vite/**"],
	"include": ["src/**/*"],
	"compilerOptions": {
		"baseUrl": ".",
		"moduleResolution": "Node10",
		"ignoreDeprecations": "6.0",
		"resolveJsonModule": true,
		"allowJs": true,
		"jsx": "react-jsx",
		"target": "ESNext",
		"lib": [ "DOM","DOM.Iterable","ES2019"],
		"module": "ESNext",
		"types": ["vite/client"],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"],
			"@wordpress/element": ["./src/shims/wordpress-element.ts"]
		}
	}
}
